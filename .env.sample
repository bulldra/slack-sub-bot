# SECRETS: JSON文字列として全てのシークレットを格納する環境変数
# テスト時は secrets.json ファイルを配置するか、SECRETS_JSON 環境変数を設定
SECRETS='{"SLACK_BOT_TOKEN":"xoxb-xxx","SLACK_USER_TOKEN":"xoxp-xxx","SHARE_CHANNEL_ID":"C0000000000","IMAGE_CHANNEL_ID":"C0000000000","OPENAI_API_KEY":"sk-xxx","GITHUB_TOKEN":"ghp_xxx","X_API_KEY":"","X_API_SECRET":"","X_ACCESS_TOKEN":"","X_ACCESS_TOKEN_SECRET":""}'

# GCP設定 (Geminiエージェント用、contextから渡される)
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# GCSバケット設定
GCS_BUCKET_JSON='{"bucket_name":"your-bucket-name"}'

# URL戦略設定 (scraping_utils用)
URL_STRATEGY_JSON='{}'
